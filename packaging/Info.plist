<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Bundle identity for the shipped Tarmac.app. scripts/bundle.sh copies this into
  Contents/Info.plist and stamps the version from $VERSION (default 0.1.0).

  - CFBundleIdentifier must stay STABLE across releases (Gatekeeper / upgrade
    identity keys off it). Pick once, never churn.
  - LSMinimumSystemVersion is 14.0 to match the binary's minos (Package.swift
    .macOS(.v14)) — NOT the build SDK version.
  - LSUIElement is false: Tarmac is a windowed cockpit, not a menu-bar agent.
-->
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleExecutable</key>
	<string>TarmacApp</string>
	<key>CFBundleIdentifier</key>
	<string>com.pingeplin.tarmac</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>Tarmac</string>
	<key>CFBundleDisplayName</key>
	<string>Tarmac</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>0.4.0</string>
	<key>CFBundleVersion</key>
	<string>0.4.0</string>
	<key>CFBundleIconFile</key>
	<string>Tarmac</string>
	<key>LSMinimumSystemVersion</key>
	<string>14.0</string>
	<key>LSUIElement</key>
	<false/>
	<key>NSHighResolutionCapable</key>
	<true/>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<key>NSHumanReadableCopyright</key>
	<string>Tarmac</string>
</dict>
</plist>
